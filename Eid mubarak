<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Eid Mubarak 💖</title>

<style>
    body {
        margin: 0;
        background: #0D1B2A;
        overflow: hidden;
        text-align: center;
        font-family: Arial;
        color: gold;
    }

    h1 {
        margin-top: 120px;
        font-size: 32px;
    }

    button {
        margin-top: 50px;
        padding: 15px 25px;
        font-size: 18px;
        border: none;
        border-radius: 10px;
        background: gold;
        color: black;
    }

    .heart {
        position: absolute;
        color: pink;
        font-size: 20px;
        animation: float 5s linear infinite;
    }

    @keyframes float {
        from { transform: translateY(100vh); }
        to { transform: translateY(-10vh); }
    }
</style>
</head>

<body>

<h1 id="text"></h1>
<button onclick="celebrate()">Celebrate 🎉</button>

<audio id="music" src="music.mp3" loop></audio>

<script>
let message = "Eid Mubarak Manahil 💖";
let index = 0;
let text = document.getElementById("text");

// 🎵 play music
document.getElementById("music").play();

// ✍️ typing effect
function typeWriter() {
    if (index < message.length) {
        text.innerHTML += message.charAt(index);
        index++;
        setTimeout(typeWriter, 120);
    }
}
typeWriter();

// 🎆 celebrate
function celebrate() {

    // vibration (mobile)
    if (navigator.vibrate) {
        navigator.vibrate(200);
    }

    // color change
    for (let i = 0; i < 20; i++) {
        setTimeout(() => {
            text.style.color = '#' + Math.floor(Math.random()*16777215).toString(16);
        }, i * 100);
    }

    // hearts 💖
    for (let i = 0; i < 15; i++) {
        let heart = document.createElement("div");
        heart.innerHTML = "💖";
        heart.className = "heart";
        heart.style.left = Math.random() * 100 + "vw";
        heart.style.fontSize = (20 + Math.random()*20) + "px";

        document.body.appendChild(heart);

        setTimeout(() => heart.remove(), 5000);
    }
}
</script>

</body>
</html>
